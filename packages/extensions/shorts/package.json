    "eslint": "10.0.3",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "web-ext": "9.3.0",
    "webpack": "5.105.4",
    "webpack-cli": "6.0.1"
  },
